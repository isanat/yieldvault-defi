# Database Configuration
# For local development with SQLite
DATABASE_URL=file:./db/custom.db

# For production with Neon.tech PostgreSQL
# DATABASE_URL=postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/yieldvault?sslmode=require

# Wallet Connect Project ID (get from https://cloud.walletconnect.com/)
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_project_id_here

# Blockchain RPC URLs
POLYGON_RPC_URL=https://polygon-rpc.com
MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com

# Smart Contract Addresses (after deployment)
NEXT_PUBLIC_VAULT_ADDRESS=
NEXT_PUBLIC_REFERRAL_ADDRESS=
NEXT_PUBLIC_CONFIG_ADDRESS=
VAULT_ADDRESS=
CONFIG_ADDRESS=

# Bot Configuration
BOT_PRIVATE_KEY=
HARVEST_BOT_PRIVATE_KEY=
REBALANCE_BOT_PRIVATE_KEY=

# Strategy Addresses (after deployment)
AAVE_STRATEGY_ADDRESS=
QUICKSWAP_STRATEGY_ADDRESS=

# Admin Configuration
ADMIN_ADDRESSES=0x1234567890123456789012345678901234567890
ADMIN_API_KEY=your_secure_api_key_here

# Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# API Keys
COINGECKO_API_KEY=
